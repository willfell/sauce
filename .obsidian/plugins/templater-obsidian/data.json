{
  "command_timeout": 5,
  "templates_folder": "Docs/Meta/Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": false,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "Docs/Meta/Templater",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "spice/meetings/notes",
      "template": "ranch/templates/Meeting.md"
    },
    {
      "folder": "spice/meetings/hubs",
      "template": "ranch/templates/Meeting Hub.md"
    },
    {
      "folder": "spice/scratch",
      "template": "ranch/templates/Scratch.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "",
    "Docs/Meta/Templates/Validate.md",
    "Docs/Meta/Templates/Audit.md",
    "ranch/templates/Validate.md",
    "ranch/templates/Audit.md"
  ],
  "startup_templates": [
    "",
    "ranch/templates/Template, Project Task Create Listener.md"
  ],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [
    {
      "folder": ""
    }
  ]
