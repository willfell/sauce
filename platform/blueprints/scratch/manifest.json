{
  "name": "scratch",
  "version": "0.2.6",
  "kind": "blueprint",
  "module_directory": "scratch",
  "skills_dir": ".claude/skills/scratch",
  "description": "Low-friction quick-capture scratch notes. Per-day sub-folders under spice/scratch/YYYY/MM-MMMM/YYYY-MM-DD/. v0.2.0 redesign: nav-button opens-or-creates today's day-hub Scratch-Day-YYYY-MM-DD.md (collision-free with daily note); day-hub embeds ScratchNewButton (helper using customJS.AccentButton) for timestamped Scratch-YYYY-MM-DD-HH-mm.md siblings; ScratchHubCards target path fixed. v0.2.1 patch: (a) Scratch Day Hub.md ScratchDayList args wrapped in array (customjs-guard requires Array); (b) nav-button icon set to 'scratch' (new ICONS entry in nav-buttons@2.6.1). v0.2.2 patch: (a) frontmatter date values now quoted (Obsidian auto-parses unquoted YYYY-MM-DD to Date objects, broke dv.current().day === string equality); (b) ScratchDayList + new ScratchDayActions helpers normalize day across string/Date/Luxon via _coerceDay shim; (c) Scratch Day Hub.md replaces stacked ScratchNewButton + markdown Hub link with single ScratchDayActions helper that renders + New Scratch and Hub buttons inline below the nav row.",
  "depends_on": [
    {
      "name": "nav-buttons",
      "range": ">=2.6.1"
    },
    {
      "name": "customjs-guard",
      "range": ">=1.0.0"
    },
    {
      "name": "cards",
      "range": ">=0.2.4"
    },
    {
      "name": "accent-button",
      "range": ">=0.1.0"
    },
    {
      "name": "platform-claude",
      "range": ">=0.1.1"
    }
  ],
  "customjs_classes": [
    "ScratchHubCards",
    "ScratchDayList",
    "ScratchNewButton",
    "ScratchDayActions",
    "ScratchLeafActions",
    "ScratchHubActions"
  ],
  "files": [
    {
      "source": "templates/Scratch.md",
      "dest": "{{templates_path}}/Scratch.md"
    },
    {
      "source": "templates/Scratch Day Hub.md",
      "dest": "{{templates_path}}/Scratch Day Hub.md"
    },
    {
      "source": "templates/Scratch Hub.md",
      "dest": "{{module_directory}}/Scratch.md"
    },
    {
      "source": "helpers/scratch-hub-cards.js",
      "dest": "{{scripts_path}}/scratch/scratch-hub-cards.js"
    },
    {
      "source": "helpers/scratch-day-list.js",
      "dest": "{{scripts_path}}/scratch/scratch-day-list.js"
    },
    {
      "source": "helpers/scratch-new-button.js",
      "dest": "{{scripts_path}}/scratch/scratch-new-button.js"
    },
    {
      "source": "helpers/scratch-day-actions.js",
      "dest": "{{scripts_path}}/scratch/scratch-day-actions.js"
    },
    {
      "source": "helpers/scratch-leaf-actions.js",
      "dest": "{{scripts_path}}/scratch/scratch-leaf-actions.js"
    },
    {
      "source": "helpers/scratch-hub-actions.js",
      "dest": "{{scripts_path}}/scratch/scratch-hub-actions.js"
    }
  ],
  "claude_surface": [
    {
      "kind": "command",
      "source": "commands/scratch.md",
      "dest": ".claude/commands/scratch.md"
    },
    {
      "kind": "skill",
      "source": "skills/new-scratch/SKILL.md",
      "dest": "{{skills_dir}}/new-scratch/SKILL.md"
    },
    {
      "kind": "claude_md_row",
      "table": "resolvers",
      "row": {
        "topic": "Scratch",
        "path": "{{module_directory}}",
        "command": "/scratch"
      }
    }
  ],
  "nav_buttons": [
    {
      "id": "scratch-day-hub",
      "label": "Scratch",
      "icon": "scratch",
      "order": 130,
      "action": {
        "type": "runTemplaterTemplate",
        "template_source": "Scratch Day Hub.md",
        "folder_prefix": "{{module_directory}}",
        "folder_date_pattern": "YYYY/MM-MMMM/YYYY-MM-DD",
        "filename_prefix": "Scratch-Day-",
        "filename_date_pattern": "YYYY-MM-DD",
        "filename_suffix": ""
      }
    }
  ],
  "templater_folder_templates": [
    {
      "folder": "{{module_directory}}",
      "template": "{{templates_path}}/Scratch.md"
    }
  ],
  "rule_fragments": [
    {
      "target": "scratch",
      "fragment": {
        "scope": {
          "path_glob": "spice/scratch/**/Scratch-2*.md"
        },
        "required_frontmatter": {
          "created": {
            "required": true,
            "type": "string"
          },
          "type": {
            "required": true,
            "equals": "scratch"
          },
          "day": {
            "required": true,
            "type": "string"
          }
        },
        "naming_pattern": "^Scratch-\\d{4}-\\d{2}-\\d{2}-\\d{2}-\\d{2}\\.md$"
      }
    },
    {
      "target": "scratch-day-hub",
      "fragment": {
        "scope": {
          "path_glob": "spice/scratch/**/Scratch-Day-*.md"
        },
        "required_frontmatter": {
          "created": {
            "required": true,
            "type": "string"
          },
          "type": {
            "required": true,
            "equals": "scratch-day"
          },
          "day": {
            "required": true,
            "type": "string"
          }
        },
        "naming_pattern": "^Scratch-Day-\\d{4}-\\d{2}-\\d{2}\\.md$"
      }
    }
  ]
}
