      }
    },
    {
      "target": "cowork",
      "fragment": {
        "scope": { "path_glob": "spice/cowork/monthly/**/*.md" },
        "required_frontmatter": {
          "type":        { "required": true, "type": "string", "equals": "cowork-monthly" },
