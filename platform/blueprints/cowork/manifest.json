      "target": "cowork",
      "fragment": {
        "scope": { "path_glob": "spice/cowork/Daily Hub.md" },
        "required_frontmatter": { "type": { "required": true, "type": "string", "equals": "cowork-daily-hub" } },
        "required_tags": [{ "tag": "cowork-hub" }, { "tag": "daily-hub" }]
