              "by_type_source": "engagement-types/<type>.json#required_fields",
              "common_required": {
                "id":   { "required": true, "type": "string", "matches": "^[a-z][a-z0-9-]+$" },
                "type": { "required": true, "type": "string" }
              }
            }
          }
        }
      }
    },
