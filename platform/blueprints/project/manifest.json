{
  "name": "project",
  "version": "1.3.8",
  "kind": "blueprint",
  "module_directory": "projects",
  "description": "Per-project atlas + map + Kanban board with hierarchical tasks (task hub + notes + task-board + folder-style sub-task cards), workstream-tagged cards, and All-Projects hub. v1.3.3 PATCH: ProjectNavButtons migrated to customJS.AccentButton.render(...) instead of inline _renderActionButton (4 call sites). Visual surface IDENTICAL; pure dedupe. Adds accent-button >=0.1.0 dep (renamed from beacon-button in v0.24.0).",
  "depends_on": [
    { "name": "nav-buttons",    "range": ">=2.3.0" },
    { "name": "customjs-guard", "range": ">=1.0.0" },
    { "name": "cards",          "range": ">=0.1.1" },
    { "name": "accent-button",  "range": ">=0.1.0" },
    { "name": "convenience",    "range": ">=0.1.0" }
  ],
  "customjs_classes": [
    "ProjectNavButtons",
    "ProjectWorkstreams",
    "ProjectWorkstreamManager",
    "ProjectsHubCards",
    "ProjectNotesCards",
    "ProjectReferencedByCards"
  ],
  "pre_install": [
    { "type": "delete", "path": "boards/To-Do-Board.md" }
  ],
  "files": [
    { "source": "templates/Project.md",                  "dest": "{{templates_path}}/Template, Project.md" },
    { "source": "templates/Project Map.md",              "dest": "{{templates_path}}/Template, Project Map.md" },
    { "source": "templates/Project Board.md",            "dest": "{{templates_path}}/Template, Project Board.md" },
    { "source": "templates/Kanban Card.md",              "dest": "{{templates_path}}/Template, Kanban Card.md" },
    { "source": "templates/Task Note.md",                "dest": "{{templates_path}}/Template, Task Note.md" },
    { "source": "templates/Task Board.md",               "dest": "{{templates_path}}/Template, Task Board.md" },
    { "source": "templates/Task Board Card.md",          "dest": "{{templates_path}}/Template, Task Board Card.md" },
    { "source": "helpers/project-nav-buttons.js",        "dest": "{{scripts_path}}/project/project-nav-buttons.js" },
    { "source": "helpers/project-workstream-manager.js", "dest": "{{scripts_path}}/project/project-workstream-manager.js" },
    { "source": "helpers/project-workstreams.js",        "dest": "{{scripts_path}}/project/project-workstreams.js" },
    { "source": "helpers/projects-hub-cards.js",         "dest": "{{scripts_path}}/project/projects-hub-cards.js" },
    { "source": "helpers/project-notes-cards.js",        "dest": "{{scripts_path}}/project/project-notes-cards.js" },
    { "source": "helpers/project-referenced-by-cards.js","dest": "{{scripts_path}}/project/project-referenced-by-cards.js" },
    { "source": "content/Projects.md",                   "dest": "{{module_directory}}/Projects.md" }
  ],
  "nav_buttons": [
    {
      "id": "projects-hub",
      "label": "Projects",
      "icon": "projects",
      "order": 100,
      "action": { "type": "openLink", "target": "{{module_directory}}/Projects.md" }
    }
  ],
  "post_install": [
    {
      "type": "notice",
      "message": "Project blueprint v1.0.0 installed at spice/projects/. To create your first project: open spice/projects/Projects.md (Cmd+O → search 'Projects') and click the 'New Project' action button. Per-project Kanban cards auto-promote to folder-style (tasks/<X>/<X>.md and board/<Y>/<Y>.md) via Templater. Workstream tagging on cards via the Change/Assign widget rendered on each card. Cmd+R required after this install to load the 3 CustomJS classes."
    }
  ],
  "bootstrap_contributions": [
    { "kind": "engagement_field_offer", "engagement_field_id": "project.primary_kanban_filter", "type": "string", "prompt": "Filter expression for this engagement's primary kanban (blank = no filter)", "consumed_by_types": ["w2-fte", "consulting", "personal"] }
  ],
  "rule_fragments": [
    {
      "target": "project",
      "fragment": {
        "scope": { "path_glob": "spice/projects/*/Project.md" },
        "required_frontmatter": {
          "created":     { "required": true, "type": "string" },
          "description": { "required": true, "type": "string" },
          "workstreams": { "required": true, "type": "list" }
        },
        "required_tags": [{ "tag": "project" }]
      }
    }
  ]
}
