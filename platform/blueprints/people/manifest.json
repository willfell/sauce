{
  "name": "people",
  "version": "0.1.2",
  "kind": "blueprint",
  "module_directory": "people",
  "description": "Per-person notes under spice/people/<First Last>.md, with hub at spice/people/People.md and shared rendering via people-rendering mechanism. Materializes Templater folder template + global People nav-button.",
  "depends_on": [
    { "name": "people-rendering", "range": ">=0.1.0" },
    { "name": "customjs-guard",   "range": ">=1.0.0" },
    { "name": "nav-buttons",      "range": ">=2.5.3" },
    { "name": "accent-button",    "range": ">=0.1.0" },
    { "name": "cards",            "range": ">=0.2.4" }
  ],
  "customjs_classes": ["PeopleHubCards", "NewPersonButton", "PersonNavButtons"],
  "files": [
    { "source": "scripts/people-hub-cards.js",     "dest": "{{scripts_path}}/people/people-hub-cards.js" },
    { "source": "scripts/new-person-button.js",    "dest": "{{scripts_path}}/people/new-person-button.js" },
    { "source": "scripts/person-nav-buttons.js",   "dest": "{{scripts_path}}/people/person-nav-buttons.js" },
    { "source": "templates/Template, People.md",   "dest": "{{templates_path}}/Template, People.md" },
    { "source": "content/People.md",               "dest": "{{module_directory}}/People.md" }
  ],
  "templater_folder_templates": [
    { "folder": "{{module_directory}}", "template": "{{templates_path}}/Template, People.md" }
  ],
  "nav_buttons": [
    {
      "id": "people-hub",
      "label": "People",
      "icon": "people",
      "order": 60,
      "action": { "type": "openLink", "target": "{{module_directory}}/People.md" }
    }
  ],
  "post_install": [
    {
      "type": "notice",
      "message": "people@0.1.0 installed. Open spice/people/People.md to see the hub. Click '+ New Person' to create. Existing People notes (if migrated from a consumer vault) survive as long as they live under spice/people/."
    }
  ],
  "bootstrap_contributions": [
    { "kind": "engagement_field_offer", "engagement_field_id": "people.inner_circle_people", "type": "string[]", "prompt": "Inner-circle people for iMessage filtering (comma-separated names)", "consumed_by_types": ["personal"] },
    { "kind": "context_file_offer",     "path_template": "spice/cowork/context/{{engagement_id}}/people.md",     "source_template": "engagement-templates/personal/people.md", "consumed_by_types": ["personal"] }
  ],
  "rule_fragments": [
    {
      "target": "people",
      "fragment": {
        "scope": { "path_glob": "spice/people/*.md", "exclude_basenames": ["People.md"] },
        "required_frontmatter": {
          "tags": { "required": true, "type": "list", "contains": ["person"] }
        },
        "naming_pattern": "^[A-Z][a-zA-Z'\\- ]+ [A-Z][a-zA-Z'\\- ]+\\.md$"
      }
    }
  ]
}
