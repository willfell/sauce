{
  "name": "finance",
  "version": "0.2.9",
  "kind": "blueprint",
  "module_directory": "finance",
  "description": "Finance blueprint covering Budgets + Paychecks + Invoices under spice/finance/. Top hub Finance.md aggregates pending items from all three sub-areas. Budgets/Paychecks are flat dated entities; Invoices use a per-month folder ecosystem mirroring trips/<slug>/. Status pills (Planning/In Progress/Done) derived from frontmatter via shared FinanceStatus helper. v0.2.7 PATCH: 8 outline-accent button call sites migrated to customJS.AccentButton.render. v0.2.8 PATCH (in-cycle CF-1): InvoiceControls Save now also recomputes amount = round(rate * hours, 2) on save; Save's enabled state additionally considers amount drift (enabled when stored amount != rate * hours) so stale-amount entities can be re-synced without changing the rate. Misleading caveat note removed.",
  "depends_on": [
    { "name": "nav-buttons",    "range": ">=2.5.2" },
    { "name": "cards",          "range": ">=0.2.3" },
    { "name": "customjs-guard", "range": ">=1.0.0" },
    { "name": "accent-button",  "range": ">=0.1.0" }
  ],
  "customjs_classes": [
    "FinanceStatus",
    "FinanceHubCards",
    "BudgetsCards",
    "PaychecksCards",
    "InvoicesCards",
    "NewBudgetButton",
    "NewPaycheckButton",
    "NewInvoiceButton",
    "InvoiceNavButtons",
    "FinanceFrontmatter",
    "BudgetNavButtons",
    "PaycheckNavButtons",
    "BudgetCategoriesEditor",
    "PaycheckExpensesEditor",
    "InvoiceTimeLogEditor",
    "InvoiceControls"
  ],
  "files": [
    { "source": "helpers/finance-status.js",       "dest": "{{scripts_path}}/finance/finance-status.js" },
    { "source": "helpers/finance-hub-cards.js",    "dest": "{{scripts_path}}/finance/finance-hub-cards.js" },
    { "source": "helpers/budgets-cards.js",        "dest": "{{scripts_path}}/finance/budgets-cards.js" },
    { "source": "helpers/paychecks-cards.js",      "dest": "{{scripts_path}}/finance/paychecks-cards.js" },
    { "source": "helpers/invoices-cards.js",       "dest": "{{scripts_path}}/finance/invoices-cards.js" },
    { "source": "helpers/new-budget-button.js",    "dest": "{{scripts_path}}/finance/new-budget-button.js" },
    { "source": "helpers/new-paycheck-button.js",  "dest": "{{scripts_path}}/finance/new-paycheck-button.js" },
    { "source": "helpers/new-invoice-button.js",   "dest": "{{scripts_path}}/finance/new-invoice-button.js" },
    { "source": "helpers/invoice-nav-buttons.js",  "dest": "{{scripts_path}}/finance/invoice-nav-buttons.js" },
    { "source": "helpers/finance-frontmatter.js",       "dest": "{{scripts_path}}/finance/finance-frontmatter.js" },
    { "source": "helpers/budget-nav-buttons.js",        "dest": "{{scripts_path}}/finance/budget-nav-buttons.js" },
    { "source": "helpers/paycheck-nav-buttons.js",      "dest": "{{scripts_path}}/finance/paycheck-nav-buttons.js" },
    { "source": "helpers/budget-categories-editor.js",  "dest": "{{scripts_path}}/finance/budget-categories-editor.js" },
    { "source": "helpers/paycheck-expenses-editor.js",  "dest": "{{scripts_path}}/finance/paycheck-expenses-editor.js" },
    { "source": "helpers/invoice-time-log-editor.js",   "dest": "{{scripts_path}}/finance/invoice-time-log-editor.js" },
    { "source": "helpers/invoice-controls.js",          "dest": "{{scripts_path}}/finance/invoice-controls.js" },

    { "source": "content/Finance.md",              "dest": "{{module_directory}}/Finance.md" },
    { "source": "content/Budgets.md",              "dest": "{{module_directory}}/budgets/Budgets.md" },
    { "source": "content/Paychecks.md",            "dest": "{{module_directory}}/paychecks/Paychecks.md" },
    { "source": "content/Invoices.md",             "dest": "{{module_directory}}/invoices/Invoices.md" },

    { "source": "templates/Budget Template.md",         "dest": "{{templates_path}}/Template, Budget.md" },
    { "source": "templates/Paycheck Template.md",       "dest": "{{templates_path}}/Template, Paycheck.md" },
    { "source": "templates/Invoice Template.md",        "dest": "{{templates_path}}/Template, Invoice.md" },
    { "source": "templates/Time Log Template.md",       "dest": "{{templates_path}}/Template, Time Log.md" },
    { "source": "templates/Invoice Board.md",           "dest": "{{templates_path}}/Template, Invoice Board.md" },
    { "source": "templates/Invoice Board Card.md",      "dest": "{{templates_path}}/Template, Invoice Board Card.md" }
  ],
  "nav_buttons": [
    {
      "id": "finance-hub",
      "label": "Finance",
      "icon": "finance",
      "order": 120,
      "action": { "type": "openLink", "target": "{{module_directory}}/Finance.md" }
    }
  ],
  "templater_folder_templates": [
    { "folder": "{{module_directory}}/budgets",   "template": "{{templates_path}}/Template, Budget.md" },
    { "folder": "{{module_directory}}/paychecks", "template": "{{templates_path}}/Template, Paycheck.md" }
  ],
  "post_install": [
    {
      "type": "notice",
      "message": "Finance blueprint v0.1.0 installed at spice/finance/. Open spice/finance/Finance.md and click 'New Budget' / 'New Paycheck' / 'New Invoice' to scaffold entries. Status pills (Planning/In Progress/Done) derive from frontmatter at render time. Cmd+R required after this install to load 9 CustomJS classes."
    }
  ],
  "rule_fragments": []
}
