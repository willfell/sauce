{
  "schema_version": 1,
  "contributions": {
    "meetings": [
      {
        "blueprint": "meetings",
        "id": "meeting",
        "label": "New Meeting",
        "icon": "users-plus",
        "prompts": [
          {
            "key": "title",
            "label": "Meeting title",
            "type": "string",
            "required": true
          }
        ],
        "destination": {
          "folder_prefix": "spice/meetings/notes",
          "filename_prefix": "{{prompts.title}}-",
          "folder_date_pattern": "YYYY/MM-MMMM",
          "filename_date_pattern": "YYYY-MM-DD",
          "filename_suffix": ""
        },
        "frontmatter_template": {
          "date": "{{now.YYYY-MM-DDTHH:mm:ssZ}}",
          "created_at": "{{now.YYYY-MM-DDTHH:mm:ssZ}}",
          "type": "meeting",
          "summary": "",
          "attendees": [],
          "people": [],
          "tags": [],
          "cssclasses": [
            "wide"
          ]
        },
        "inline_body": "```dataviewjs\nawait dv.view(\"ranch/views/customjs-guard\", { class: \"SpaceNavButtons\" });\n```\n",
        "render_in": {
          "kind": "hub",
          "target_path": "ranch/templates/Meeting Hub.md"
        }
      }
    ],
    "scratch": [
      {
        "blueprint": "scratch",
        "id": "scratch",
        "label": "+ New Scratch",
        "icon": "pencil-plus",
        "prompts": [
          {
            "key": "title",
            "label": "Scratch title (optional)",
            "type": "string",
            "required": false
          }
        ],
        "destination": {
          "folder_prefix": "spice/scratch/{{current_file.frontmatter.day}}-routed",
          "filename_prefix": "Scratch-{{current_file.frontmatter.day}}-",
          "filename_date_pattern": "HH-mm",
          "filename_suffix": ""
        },
        "frontmatter_template": {
          "type": "scratch",
          "created_at": "{{now.YYYY-MM-DDTHH:mm:ssZ}}",
          "day": "{{current_file.frontmatter.day}}"
        },
        "inline_body": "```dataviewjs\nawait dv.view(\"ranch/views/customjs-guard\", { class: \"SpaceNavButtons\" });\n```\n\n---\n\n```dataviewjs\nawait dv.view(\"ranch/views/customjs-guard\", { class: \"ScratchLeafActions\" });\n```\n\n---\n",
        "render_in": {
          "kind": "hub",
          "target_path": "ranch/templates/Scratch Day Hub.md"
        }
      }
    ],
    "project": [
      {
        "blueprint": "project",
        "id": "project",
        "label": "New Project",
        "icon": "folder-plus",
        "prompts": [
          {
            "key": "name",
            "label": "Project name",
            "type": "string",
            "required": true
          },
          {
            "key": "slug",
            "type": "string",
            "derive": "slugify(prompts.name)"
          }
        ],
        "destination": {
          "folder_prefix": "spice/projects/{{prompts.slug}}",
          "filename_prefix": "{{prompts.name|sanitize-filename}}"
        },
        "frontmatter_template": {
          "type": "project",
          "created_at": "{{now.YYYY-MM-DDTHH:mm:ssZ}}",
          "description": "",
          "status": "idea",
          "status_changed_at": "{{now.YYYY-MM-DD}}",
          "workstreams": [],
          "teams": [],
          "products": [],
          "tags": []
        },
        "body_template": "ranch/templates/Template, Project.md",
        "extra_files": [
          {
            "filename_pattern": "Project Map.md",
            "body_template": "ranch/templates/Template, Project Map.md"
          },
          {
            "filename_pattern": "{{prompts.slug}}-board.md",
            "body_template": "ranch/templates/Template, Project Board.md"
          },
          {
            "subfolder": "docs",
            "filename_pattern": "Docs.md",
            "body_template": "ranch/templates/Template, Docs Hub.md"
          }
        ],
        "render_in": {
          "kind": "hub",
          "target_path": "spice/projects/Projects.md"
        }
      },
      {
        "blueprint": "project",
        "id": "doc-note",
        "label": "+ New Doc",
        "icon": "file-plus",
        "prompts": [
          {
            "key": "title",
            "label": "Doc title",
            "type": "string",
            "required": true,
            "validate": "safe-filename"
          }
        ],
        "destination": {
          "folder_prefix": "spice/projects/{{current_file.frontmatter.project_slug}}/docs",
          "filename_prefix": "{{prompts.title|sanitize-filename}}"
        },
        "frontmatter_template": {
          "type": "doc-note",
          "created_at": "{{now.YYYY-MM-DDTHH:mm:ssZ}}",
          "project": "[[{{current_file.frontmatter.project_name}}]]",
          "project_slug": "{{current_file.frontmatter.project_slug}}",
          "tags": [
            "doc-note"
          ]
        },
        "body_template": "ranch/templates/Template, Doc Note.md",
        "render_in": {
          "kind": "hub",
          "target_path": "ranch/templates/Template, Docs Hub.md"
        }
      }
    ]
  },
